settings:
  application:
    mode: dev
    host: 0.0.0.0
    name: productManager
    port: 10082
    # 数据权限开关；true 时 sys_role.data_scope 真生效（UI '数据范围' 下拉）。
    # 本地联调建议保持 false；上线/复现数据权限相关 bug 时打开。
    # enabledp: true
  logger:
    enableddb: true
  jwt:
    secret: replace-with-a-local-secret
    timeout: 3600
  database:
    driver: mysql
    source: user:password@tcp(127.0.0.1:3306)/full_stack_test_v1?charset=utf8&parseTime=True&loc=Local&timeout=1000ms
  gen:
    frontpath: ../vue-vben-admin/apps/web-antd/src
