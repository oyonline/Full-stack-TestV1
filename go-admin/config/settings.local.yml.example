settings:
  application:
    mode: dev
    host: 0.0.0.0
    name: productManager
    port: 10082
    # 数据权限开关；phase2 已全量启用（C7-7），默认随 settings.yml = true。
    # 仅当本地需要复现 phase1 行为或排查 dataScope 相关 bug 时显式覆盖为 false。
    enabledp: true
  logger:
    enableddb: true
  jwt:
    secret: replace-with-a-local-secret
    timeout: 3600
  database:
    driver: mysql
    source: user:password@tcp(127.0.0.1:3306)/full_stack_test_v1?charset=utf8&parseTime=True&loc=Local&timeout=1000ms
  gen:
    frontpath: ../vue-vben-admin/apps/web-antd/src
