package service

import (
	"go-admin/app/{{.PackageName}}/models"
	"go-admin/common/baseservice"
)

// {{.ClassName}} 通过嵌入 baseservice.BaseService[models.{{.ClassName}}] 自动获得
// GetPage/Get/Insert/Update/Remove 五件套。
//
// 如需差异行为（多表 join、自定义 where、软删除回滚等），在本类型上声明同名方法
// 即可覆盖默认实现；外层方法优先于嵌入字段方法。
//
// 不再使用 *actions.DataPermission 做数据权限过滤。需要数据权限的模块自行覆盖
// 相关方法并组合 actions.Permission(table, p) scope。
type {{.ClassName}} struct {
	baseservice.BaseService[models.{{.ClassName}}]
}
