# 端口号
VITE_PORT=5666

# 应用标题
VITE_APP_TITLE=企业中后台管理系统

VITE_BASE=/

# 接口地址（开发环境后端地址 - 使用实际IP，支持局域网访问）
VITE_GLOB_API_URL=http://172.16.97.127:10082/api

# 是否开启 Nitro Mock服务，true 为开启，false 为关闭
VITE_NITRO_MOCK=false

# 是否打开 devtools，true 为打开，false 为关闭
VITE_DEVTOOLS=false

# 是否注入全局loading
VITE_INJECT_APP_LOADING=true
